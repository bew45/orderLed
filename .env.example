PORT=8788
HOST=127.0.0.1

# OpenRouter is optional but recommended for accurate extraction.
# Without it, OrderLedger falls back to basic OCR heuristics.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PaddleOCR runtime. Leave empty to use "python" from PATH.
ORDERLEDGER_PADDLE_PYTHON=
ORDERLEDGER_PADDLE_LANG=th
ORDERLEDGER_PADDLE_TIMEOUT_MS=90000

# Optional cache for OCR/LLM intermediate JSON files.
ORDERLEDGER_WRITE_PROCESSING_CACHE=false
